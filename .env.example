# raster-forge — переменные окружения (опционально)
# Копируйте в .env для локальной разработки

# Путь к конфигу по умолчанию (переопределяет config.yaml)
# RASTER_FORGE_CONFIG=custom-config.yaml

# Путь ко входной/выходной директории
# RASTER_FORGE_INPUT=./documents
# RASTER_FORGE_OUTPUT=./processed

# Уровень логирования: debug, info, warn, error
# RASTER_FORGE_LOG_LEVEL=debug
